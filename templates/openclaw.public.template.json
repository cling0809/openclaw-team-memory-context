{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "__GATEWAY_TOKEN__"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "__WORKSPACE_DIR__",
      "thinkingDefault": "high",
      "verboseDefault": "on",
      "timeoutSeconds": 900,
      "maxConcurrent": 4,
      "elevatedDefault": "on",
      "contextPruning": {
        "mode": "cache-ttl"
      },
      "compaction": {
        "mode": "default",
        "memoryFlush": {
          "enabled": true
        }
      },
      "memorySearch": {
        "enabled": true,
        "sources": [
          "memory",
          "sessions"
        ],
        "query": {
          "maxResults": 8,
          "hybrid": {
            "enabled": true,
            "mmr": {
              "enabled": true,
              "lambda": 0.7
            },
            "temporalDecay": {
              "enabled": true,
              "halfLifeDays": 30
            }
          }
        },
        "sync": {
          "onSessionStart": true,
          "onSearch": true,
          "watch": true
        },
        "cache": {
          "enabled": true,
          "maxEntries": 5000
        },
        "experimental": {
          "sessionMemory": true
        }
      },
      "model": {
        "primary": "github-copilot/gpt-5.4",
        "fallbacks": []
      },
      "models": {
        "github-copilot/gpt-5.4": {
          "alias": "default"
        },
        "github-copilot/claude-opus-4.6": {
          "alias": "claude"
        },
        "google/gemini-3-pro-preview": {
          "alias": "gemini"
        }
      },
      "subagents": {
        "maxChildrenPerAgent": 4,
        "maxConcurrent": 6,
        "maxSpawnDepth": 3,
        "runTimeoutSeconds": 900,
        "model": "github-copilot/gpt-5.4"
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "不良帅·李星云",
        "identity": {
          "emoji": "⚔️",
          "name": "不良帅·李星云（天暗星）",
          "theme": "总控调度·不良帅"
        },
        "thinkingDefault": "high",
        "reasoningDefault": "stream",
        "workspace": "__WORKSPACE_DIR__",
        "subagents": {
          "allowAgents": [
            "*"
          ]
        }
      },
      {
        "id": "coder",
        "name": "天祐星·石瑶",
        "identity": {
          "emoji": "🛡️",
          "name": "天祐星·石瑶",
          "theme": "稳健的工程实现者"
        },
        "thinkingDefault": "high",
        "reasoningDefault": "stream",
        "workspace": "__WORKSPACE_DIR__"
      },
      {
        "id": "code-assist",
        "name": "天速星·段成天",
        "identity": {
          "emoji": "⚡",
          "name": "天速星·段成天",
          "theme": "快速补位、读改并行的代码助手"
        },
        "thinkingDefault": "high",
        "reasoningDefault": "stream",
        "workspace": "__WORKSPACE_DIR__"
      },
      {
        "id": "research",
        "name": "天慧星·慧明",
        "identity": {
          "emoji": "📜",
          "name": "天慧星·慧明",
          "theme": "中文优先的资料分析师"
        },
        "thinkingDefault": "high",
        "reasoningDefault": "stream",
        "workspace": "__WORKSPACE_DIR__"
      },
      {
        "id": "frontend",
        "name": "天巧星·上官云阙",
        "identity": {
          "emoji": "🎨",
          "name": "天巧星·上官云阙",
          "theme": "懂设计也能落代码的界面打磨者"
        },
        "thinkingDefault": "high",
        "reasoningDefault": "stream",
        "workspace": "__WORKSPACE_DIR__"
      },
      {
        "id": "qa",
        "name": "天损星·陆佑劫",
        "identity": {
          "emoji": "🧪",
          "name": "天损星·陆佑劫",
          "theme": "喜欢复现问题和守住回归线的验证者"
        },
        "thinkingDefault": "high",
        "reasoningDefault": "stream",
        "workspace": "__WORKSPACE_DIR__"
      },
      {
        "id": "reviewer",
        "name": "天罪星·镜心魔",
        "identity": {
          "emoji": "👁️",
          "name": "天罪星·镜心魔",
          "theme": "专挑风险和漏洞的把关者"
        },
        "thinkingDefault": "high",
        "reasoningDefault": "stream",
        "workspace": "__WORKSPACE_DIR__"
      }
    ]
  }
}