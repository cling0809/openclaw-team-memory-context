{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        },
        "responses": {
          "enabled": true,
          "files": {
            "allowUrl": true
          },
          "images": {
            "allowUrl": true
          }
        }
      }
    },
    "nodes": {
      "denyCommands": []
    },
    "reload": {
      "debounceMs": 500,
      "mode": "hybrid"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "enabled": true,
      "allowInsecureAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "__GATEWAY_TOKEN__"
    }
  },
  "auth": {
    "order": {
      "github-copilot": [
        "github-copilot:github"
      ],
      "openai-codex": [
        "openai-codex:default"
      ]
    },
    "profiles": {
      "github-copilot:github": {
        "mode": "token",
        "provider": "github-copilot"
      },
      "google:default": {
        "mode": "api_key",
        "provider": "google"
      },
      "minimax:cn": {
        "mode": "api_key",
        "provider": "minimax"
      },
      "minimax-portal:default": {
        "mode": "oauth",
        "provider": "minimax-portal"
      },
      "openai-codex:default": {
        "mode": "oauth",
        "provider": "openai-codex"
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "__AGENT_WORKSPACE_MAIN_DIR__",
      "thinkingDefault": "high",
      "verboseDefault": "on",
      "timeoutSeconds": 900,
      "maxConcurrent": 4,
      "elevatedDefault": "on",
      "imageGenerationModel": {
        "primary": "google/gemini-3-pro-image-preview"
      },
      "imageModel": {
        "primary": "google/gemini-3-pro-preview",
        "fallbacks": [
          "google/gemini-3-flash-preview"
        ]
      },
      "contextPruning": {
        "mode": "cache-ttl"
      },
      "compaction": {
        "mode": "default",
        "memoryFlush": {
          "enabled": true
        }
      },
      "memorySearch": {
        "enabled": true,
        "sources": [
          "memory",
          "sessions"
        ],
        "query": {
          "maxResults": 8,
          "hybrid": {
            "enabled": true,
            "mmr": {
              "enabled": true,
              "lambda": 0.7
            },
            "temporalDecay": {
              "enabled": true,
              "halfLifeDays": 30
            }
          }
        },
        "sync": {
          "onSessionStart": true,
          "onSearch": true,
          "watch": true
        },
        "cache": {
          "enabled": true,
          "maxEntries": 5000
        },
        "experimental": {
          "sessionMemory": true
        }
      },
      "model": {
          "primary": "minimax/MiniMax-M2.7",
        "fallbacks": []
      },
      "models": {
        "codex-cli/gpt-5.3-codex": {},
        "codex-cli/gpt-5.4": {
          "alias": "codex-cli"
        },
        "github-copilot/claude-opus-4.6": {
          "alias": "copilot-opus"
        },
        "github-copilot/gemini-3.1-pro-preview": {
          "alias": "copilot-gemini"
        },
        "github-copilot/gpt-4o": {
          "alias": "copilot-4o"
        },
        "github-copilot/gpt-5.2": {
          "alias": "copilot-gpt52"
        },
        "github-copilot/gpt-5.2-codex": {
          "alias": "copilot-codex"
        },
        "github-copilot/gpt-5.4": {
          "alias": "copilot-gpt"
        },
        "google/gemini-3-flash-preview": {
          "alias": "gemini-flash"
        },
        "google/gemini-3-pro-preview": {
          "alias": "gemini"
        },
        "minimax/MiniMax-M2.1": {
          "alias": "minimax-m2.1"
        },
        "minimax/MiniMax-M2.5": {
          "alias": "minimax-m2.5"
        },
        "minimax/MiniMax-M2.7": {
          "alias": "minimax-m2.7"
        },
        "openai-codex/gpt-5.3-codex": {
          "alias": "codex"
        },
        "openai-codex/gpt-5.4": {}
      },
      "subagents": {
        "maxChildrenPerAgent": 4,
        "maxConcurrent": 6,
        "maxSpawnDepth": 3,
        "runTimeoutSeconds": 900,
        "model": "minimax/MiniMax-M2.7"
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "不良帅·李星云",
        "identity": {
          "emoji": "⚔️",
          "name": "不良帅·李星云（天暗星）",
          "theme": "总控调度·不良帅"
        },
        "model": {
          "primary": "minimax/MiniMax-M2.7",
          "fallbacks": []
        },
        "thinkingDefault": "high",
        "reasoningDefault": "stream",
        "workspace": "__AGENT_WORKSPACE_MAIN_DIR__",
        "subagents": {
          "allowAgents": [
            "*"
          ]
        }
      },
      {
        "id": "coder",
        "name": "天祐星·石瑶",
        "identity": {
          "emoji": "🛡️",
          "name": "天祐星·石瑶",
          "theme": "稳健的工程实现者"
        },
        "model": {
          "primary": "minimax/MiniMax-M2.7",
          "fallbacks": []
        },
        "thinkingDefault": "high",
        "reasoningDefault": "stream",
        "workspace": "__AGENT_WORKSPACE_CODER_DIR__",
        "subagents": {
          "allowAgents": [
            "*"
          ]
        }
      },
      {
        "id": "code-assist",
        "name": "天速星·段成天",
        "identity": {
          "emoji": "⚡",
          "name": "天速星·段成天",
          "theme": "快速补位、读改并行的代码助手"
        },
        "model": {
          "primary": "minimax/MiniMax-M2.7",
          "fallbacks": []
        },
        "thinkingDefault": "high",
        "reasoningDefault": "stream",
        "workspace": "__AGENT_WORKSPACE_CODE_ASSIST_DIR__",
        "subagents": {
          "allowAgents": [
            "*"
          ]
        }
      },
      {
        "id": "research",
        "name": "天慧星·慧明",
        "identity": {
          "emoji": "📜",
          "name": "天慧星·慧明",
          "theme": "中文优先的资料分析师"
        },
        "model": {
          "primary": "minimax/MiniMax-M2.7",
          "fallbacks": []
        },
        "thinkingDefault": "high",
        "reasoningDefault": "stream",
        "workspace": "__AGENT_WORKSPACE_RESEARCH_DIR__",
        "subagents": {
          "allowAgents": [
            "*"
          ]
        }
      },
      {
        "id": "frontend",
        "name": "天巧星·上官云阙",
        "identity": {
          "emoji": "🎨",
          "name": "天巧星·上官云阙",
          "theme": "懂设计也能落代码的界面打磨者"
        },
        "model": {
          "primary": "minimax/MiniMax-M2.7",
          "fallbacks": []
        },
        "thinkingDefault": "high",
        "reasoningDefault": "stream",
        "workspace": "__AGENT_WORKSPACE_FRONTEND_DIR__",
        "subagents": {
          "allowAgents": [
            "*"
          ]
        }
      },
      {
        "id": "qa",
        "name": "天损星·陆佑劫",
        "identity": {
          "emoji": "🧪",
          "name": "天损星·陆佑劫",
          "theme": "喜欢复现问题和守住回归线的验证者"
        },
        "model": {
          "primary": "minimax/MiniMax-M2.7",
          "fallbacks": []
        },
        "thinkingDefault": "high",
        "reasoningDefault": "stream",
        "workspace": "__AGENT_WORKSPACE_QA_DIR__",
        "subagents": {
          "allowAgents": [
            "*"
          ]
        }
      },
      {
        "id": "reviewer",
        "name": "天罪星·镜心魔",
        "identity": {
          "emoji": "👁️",
          "name": "天罪星·镜心魔",
          "theme": "专挑风险和漏洞的把关者"
        },
        "model": {
          "primary": "minimax/MiniMax-M2.7",
          "fallbacks": []
        },
        "thinkingDefault": "high",
        "reasoningDefault": "stream",
        "workspace": "__AGENT_WORKSPACE_REVIEWER_DIR__",
        "subagents": {
          "allowAgents": [
            "*"
          ]
        }
      }
    ]
  },
  "browser": {
    "enabled": true,
    "evaluateEnabled": true,
    "headless": true
  },
  "commands": {
    "native": true,
    "nativeSkills": true,
    "ownerDisplay": "raw",
    "restart": true
  },
  "discovery": {
    "mdns": {
      "mode": "minimal"
    },
    "wideArea": {
      "enabled": false
    }
  },
  "env": {
    "shellEnv": {
      "enabled": true
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": {
          "enabled": true
        },
        "bootstrap-extra-files": {
          "enabled": true
        },
        "command-logger": {
          "enabled": true
        },
        "session-memory": {
          "enabled": true
        }
      }
    }
  },
  "models": {
    "providers": {
      "google": {
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta",
        "models": []
      },
      "minimax": {
        "api": "anthropic-messages",
        "authHeader": true,
        "baseUrl": "https://api.minimaxi.com/anthropic",
        "models": [
          {
            "id": "MiniMax-M2.1",
            "name": "MiniMax M2.1",
            "contextWindow": 200000,
            "maxTokens": 8192,
            "input": [
              "text"
            ],
            "reasoning": false,
            "cost": {
              "input": 0.3,
              "output": 1.2,
              "cacheRead": 0.03,
              "cacheWrite": 0.12
            }
          },
          {
            "id": "MiniMax-M2.5",
            "name": "MiniMax M2.5",
            "contextWindow": 200000,
            "maxTokens": 8192,
            "input": [
              "text"
            ],
            "reasoning": true,
            "cost": {
              "input": 0.3,
              "output": 1.2,
              "cacheRead": 0.03,
              "cacheWrite": 0.12
            }
          },
          {
            "id": "MiniMax-M2.7",
            "name": "MiniMax M2.7",
            "contextWindow": 200000,
            "maxTokens": 8192,
            "input": [
              "text"
            ],
            "reasoning": true,
            "cost": {
              "input": 0.3,
              "output": 1.2,
              "cacheRead": 0.03,
              "cacheWrite": 0.12
            }
          }
        ]
      },
      "minimax-portal": {
        "api": "anthropic-messages",
        "apiKey": "minimax-oauth",
        "baseUrl": "https://api.minimaxi.com/anthropic",
        "models": [
          {
            "id": "MiniMax-M2.1",
            "name": "MiniMax M2.1",
            "contextWindow": 200000,
            "maxTokens": 8192,
            "input": [
              "text"
            ],
            "reasoning": false,
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            }
          },
          {
            "id": "MiniMax-M2.5",
            "name": "MiniMax M2.5",
            "contextWindow": 200000,
            "maxTokens": 8192,
            "input": [
              "text"
            ],
            "reasoning": true,
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            }
          },
          {
            "id": "MiniMax-M2.7",
            "name": "MiniMax M2.7",
            "contextWindow": 200000,
            "maxTokens": 8192,
            "input": [
              "text"
            ],
            "reasoning": true,
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            }
          }
        ]
      }
    }
  },
  "nodeHost": {
    "browserProxy": {
      "enabled": true
    }
  },
  "plugins": {
    "entries": {
      "browser": {
        "enabled": true
      },
      "diffs": {
        "enabled": true
      },
      "llm-task": {
        "enabled": true
      },
      "lobster": {
        "enabled": true
      },
      "minimax": {
        "enabled": true
      },
      "open-prose": {
        "enabled": true
      },
      "voice-call": {
        "enabled": true
      }
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "skills": {
    "allowBundled": [],
    "entries": {
      "backend-brain": {
        "enabled": true
      },
      "bug-hunt": {
        "enabled": true
      },
      "china-research": {
        "enabled": true
      },
      "code-review-hard": {
        "enabled": true
      },
      "commit-craft": {
        "enabled": true
      },
      "doc-curator": {
        "enabled": true
      },
      "evidence-first": {
        "enabled": true
      },
      "frontend-taste": {
        "enabled": true
      },
      "logic-rigour": {
        "enabled": true
      },
      "memory-keeper": {
        "enabled": true
      },
      "prompt-polish-zh": {
        "enabled": true
      },
      "release-guard": {
        "enabled": true
      },
      "repo-dive": {
        "enabled": true
      },
      "shell-safe": {
        "enabled": true
      },
      "team-router": {
        "enabled": true
      },
      "test-forge": {
        "enabled": true
      },
      "ui-critic": {
        "enabled": true
      }
    },
    "install": {
      "nodeManager": "npm"
    },
    "load": {
      "extraDirs": [
        "__WORKSPACE_DIR__/skills"
      ],
      "watch": true,
      "watchDebounceMs": 250
    }
  },
  "tools": {
    "agentToAgent": {
      "enabled": true
    },
    "elevated": {
      "enabled": true
    },
    "exec": {
      "ask": "off",
      "security": "full"
    },
    "fs": {
      "workspaceOnly": false
    },
    "links": {
      "enabled": true,
      "maxLinks": 10,
      "timeoutSeconds": 20
    },
    "message": {
      "broadcast": {
        "enabled": true
      },
      "crossContext": {
        "allowAcrossProviders": true,
        "allowWithinProvider": true
      }
    },
    "profile": "full",
    "sessions": {
      "visibility": "all"
    },
    "web": {
      "fetch": {
        "cacheTtlMinutes": 10,
        "enabled": true,
        "maxChars": 100000,
        "timeoutSeconds": 30
      }
    }
  },
  "ui": {
    "assistant": {
      "avatar": "",
      "name": "不良帅"
    }
  },
  "update": {
    "auto": {
      "enabled": false
    },
    "channel": "stable"
  }
}